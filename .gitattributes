# Normalize line endings across platforms.
# Without this Windows checkouts can write CRLF, then `prettier --check`
# fails on Ubuntu CI even though the file is "correct" locally.

* text=auto eol=lf

# Binary blobs must round-trip byte-for-byte
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.mp4 binary
*.webm binary
*.mov binary
*.zip binary
*.gz binary
*.tar binary
*.lottie binary
*.json.gz binary

# Windows shells need CRLF
*.bat eol=crlf
*.cmd eol=crlf
*.ps1 eol=crlf

# Shell scripts must be LF even on Windows so they execute under sh/bash
*.sh eol=lf
.husky/* eol=lf
