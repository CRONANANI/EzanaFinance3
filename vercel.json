    },
    {
      "path": "/api/cron/portfolio-snapshot",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/monthly-elo",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/cron/elo-decay",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/competition-scorer",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/kairos-recompute-correlations",
      "schedule": "0 3 * * 0"
