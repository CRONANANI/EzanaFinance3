{
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/platform-aggregates",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-empire-data",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/politician-performance",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/hard-delete-accounts",
