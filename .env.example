# Ezana Finance - Next.js Environment Variables
# Copy to .env.local and fill in your values

# API Keys (client-side - use NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_ALPHA_VANTAGE_KEY=
# AlphaVantage server-only key for news sentiment API (separate from public key
# above so the news endpoint never exposes the key to the browser).
# Free tier: 25 requests/day. Get one at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
NEXT_PUBLIC_FMP_API_KEY=
NEXT_PUBLIC_NEWS_API_KEY=

# Finnhub (server-side only - API proxy hides key)
FINNHUB_API_KEY=

# Alpaca Trading (brokerage integration)
ALPACA_API_KEY=your_broker_api_key
ALPACA_API_SECRET=your_broker_api_secret
ALPACA_ENV=sandbox

# Backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin account lock API: POST /api/admin/lock-user with Authorization: Bearer <this value>
# Generate: openssl rand -base64 32  (set in Vercel + .env.local only; never commit real value)
ADMIN_LOCK_SECRET=

# Web Push (VAPID) — Settings → Notifications → Desktop; server sends via src/lib/notifications.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional subject for web-push (defaults to mailto:support@ezanafinance.com)
# VAPID_CONTACT_EMAIL=support@ezanafinance.com

# Resend (for sending emails)
RESEND_API_KEY=your_resend_api_key
# Optional: receive privacy / GDPR data-subject request notifications (defaults to VAPID_CONTACT_EMAIL if set)
# PRIVACY_REQUEST_EMAIL=privacy@ezanafinance.com
# Optional: inbox that receives landing-page contact form submissions
# (defaults to support@ezanafinance.com). Used by /api/support/contact.
# SUPPORT_INBOX=support@ezanafinance.com
# Optional: override the "From" address used for transactional sends.
# (defaults to "Ezana Contact <noreply@ezana.world>"). The domain must be
# verified in Resend before production use.
# RESEND_FROM_EMAIL=Ezana Contact <noreply@ezana.world>


# AI Stock Analyzer
ANTHROPIC_API_KEY=your_anthropic_api_key

# Financial Modeling Prep — server-only. Used by /api/market-data/upcoming-events
# (earnings, dividends, IPOs, economic calendar) and other FMP proxies. NEVER
# prefix with NEXT_PUBLIC_ — this key should not be shipped to the browser.
FMP_API_KEY=your_fmp_api_key

# App URL (used in Stripe redirects and OAuth — production: https://ezana.world)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Sign-In: configure Client ID + Client Secret in Supabase Dashboard → Authentication → Providers → Google.
# In Google Cloud Console, set Authorized redirect URI to:
#   https://<YOUR_SUPABASE_PROJECT_REF>.supabase.co/auth/v1/callback
# Authorized JS origins: http://localhost:3000 and https://ezana.world
# See docs/google-oauth-supabase.md

# Stripe — NEVER commit real keys; set in Vercel + .env.local only
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe Price IDs (Dashboard → Developers → API → Prices, or Product → Price). See src/config/pricing.js
NEXT_PUBLIC_STRIPE_PRICE_PERSONAL_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PERSONAL_ADVANCED_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_FAMILY_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_INDIVIDUAL_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_PERSONAL_ADVANCED_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_FAMILY_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL_ANNUAL=

# Empire Ranking — set to 'true' after Phase 3-4 ingestion + feature engineering is complete
NEXT_PUBLIC_EMPIRE_LIVE_DATA=false

# Platform changelog auto-summary (GitHub REST + weekly Vercel cron + optional local backfill)
# Fine-grained PAT read-only on repo. Without auth, GitHub caps at ~60 req/hr and cron/backfill may fail.
GITHUB_TOKEN=
GITHUB_REPO=CRONANANI/cronanani
