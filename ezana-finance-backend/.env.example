# Firebase
FIREBASE_PROJECT_ID=ezana-finance

# PostgreSQL (Cloud SQL or local)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ezana_finance
POSTGRES_USER=your-username
POSTGRES_PASSWORD=your-password

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# Finnhub
FINNHUB_API_KEY=your-finnhub-api-key

# QuiverQuant
QUIVER_API_KEY=your-quiver-api-key

# Alpha Vantage (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Financial Modeling Prep (https://financialmodelingprep.com/developer/docs)
FMP_API_KEY=your-fmp-key

# News API (https://newsapi.org/)
NEWS_API_KEY=your-newsapi-key

# FRED - Federal Reserve Economic Data (https://fred.stlouisfed.org/docs/api/)
FRED_API_KEY=your-fred-key

# IEX Cloud (https://iexcloud.io/)
IEX_CLOUD_API_KEY=your-iex-cloud-key

# Polygon.io (https://polygon.io/)
POLYGON_API_KEY=your-polygon-key

# Stripe Payments (https://stripe.com/)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
FRONTEND_URL=http://localhost:3000

# SendGrid Email (https://sendgrid.com/)
SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=notifications@ezanafinance.com

# Sentry Error Tracking (https://sentry.io/)
SENTRY_DSN=your-sentry-dsn

# Redis Cache (optional, for production scaling)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Node Environment
NODE_ENV=development
